# Postgres connection string for the products database.
#   - In production (Easypanel app service env), set this to the Docker-internal hostname:
#       postgres://user:pass@<service-name>:5432/<dbname>?sslmode=disable
#   - In local development, copy this file to `.env.local` and point it at a
#     reachable Postgres (e.g. a port-forwarded Easypanel DB at localhost:5432).
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable
